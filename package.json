{
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "publish:lib": "pnpm --filter @a2zb/lib build && pnpm --filter @a2zb/lib publish --no-git-checks",
    "publish:next": "pnpm --filter @a2zb/next build && pnpm --filter @a2zb/next publish --no-git-checks",
    "publish:react": "pnpm --filter @a2zb/react build && pnpm --filter @a2zb/react publish --no-git-checks",
    "publish:styles": "pnpm --filter @a2zb/styles publish --no-git-checks",
    "publish:abis": "pnpm --filter @a2zb/abis build && pnpm --filter @a2zb/abis publish --no-git-checks",
    "publish:all": "pnpm -r build && pnpm -r publish --no-git-checks"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
